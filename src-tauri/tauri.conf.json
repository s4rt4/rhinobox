{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RhinoBOX",
  "version": "0.1.0-alpha.4",
  "identifier": "com.rhinobox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RhinoBOX",
        "width": 1040,
        "height": 680,
        "minWidth": 920,
        "minHeight": 560,
        "resizable": true,
        "maximizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
